# Caddyfile snippet for fronting Nocturne with Caddy (host-network pattern).
#
# Assumes Caddy runs on the host network namespace (either native or
# network_mode: host in Docker) and reaches services via 127.0.0.1:<port>.
# Replace nocturne.bfreire.com with your real subdomain.
#
# The Nocturne stack publishes its API on 127.0.0.1:${NOCTURNE_HOST_PORT}
# (default 8731), bound to loopback only — not reachable from outside the
# host, so Caddy is the only ingress.

nocturne.bfreire.com {
    reverse_proxy 127.0.0.1:8731 {
        # Nocturne reads X-Forwarded-* (ASPNETCORE_FORWARDEDHEADERS_ENABLED=true).
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host  {host}
        header_up X-Real-IP         {remote_host}
    }

    encode zstd gzip
}
