# ============================================================================
# Nocturne — environment variables
# Copy to .env (or paste into Portainer "Environment variables") and fill in.
# Generate random passwords with:  openssl rand -base64 32
# ============================================================================

# ---- Network ---------------------------------------------------------------
# Host loopback port used by Caddy to reach the web frontend.
# Access Nocturne UI at http://<host>:8731 (or via Caddy on https://your.domain).
NOCTURNE_WEB_HOST_PORT=8731

# Internal SvelteKit port inside the web container.
NOCTURNE_WEB_PORT=1612

# Internal Kestrel HTTP port inside the API container.
NOCTURNE_API_PORT=8080

# (optional) host loopback for direct API access — only if you uncomment the
# `ports:` block on nocturne-api in docker-compose.yml.
NOCTURNE_API_HOST_PORT=8732


# ---- Public domain --------------------------------------------------------
# Used by the web container to build OAuth2 redirect URLs (Discord etc.)
# and the public-facing URLs the bot framework prints to chat. No trailing slash.
PUBLIC_BASE_DOMAIN=nocturne.bfreire.com


# ---- PostgreSQL: bootstrap superuser --------------------------------------
# Only used by the postgres image at first start to create the three
# nocturne_* roles via ./postgres/00-init.sh. After bootstrap the runtime
# services never connect with these credentials.
POSTGRES_USERNAME=nocturne_bootstrap
POSTGRES_PASSWORD=replace-me-with-openssl-rand-base64-32


# ---- PostgreSQL: Nocturne runtime roles -----------------------------------
# nocturne_migrator owns the schema and runs EF Core migrations.
# nocturne_app      handles request-time traffic with NOBYPASSRLS (Row Level
#                   Security enforces tenant isolation server-side).
# nocturne_web      owns the SvelteKit bot framework's chat_state_* tables.
# Use three DIFFERENT random secrets — do NOT reuse POSTGRES_PASSWORD here.
NOCTURNE_MIGRATOR_PASSWORD=replace-me-with-openssl-rand-base64-32
NOCTURNE_APP_PASSWORD=replace-me-with-openssl-rand-base64-32
NOCTURNE_WEB_PASSWORD=replace-me-with-openssl-rand-base64-32


# ---- Nocturne instance secret ---------------------------------------------
# Used to sign JWTs / cookies. Shared between API and web. Min 12 chars,
# prefer 32+ random.
INSTANCE_KEY=replace-me-min-32-characters-random


# ---- Chat-bot platforms (all optional) ------------------------------------
# Leave blank to disable a given platform. Bot framework no-ops gracefully.
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_APPLICATION_ID=
DISCORD_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
